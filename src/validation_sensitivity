# STEP 2 — Sensitivity Analysis: p_in and p_out Variation
# =============================================================================
print("\n" + "=" * 60)
print("STEP 2 — Sensitivity Analysis (p_in × p_out grid)")
print("=" * 60)

# Vary diagonal p_in (all roles shift equally) and off-diagonal p_out
# These ranges span ±0.15 around the base values — a conservative range
# consistent with uncertainty in ethnographic parameter estimation.

P_IN_VALUES  = [0.45, 0.50, 0.55, 0.60, 0.65, 0.70, 0.75, 0.80]
P_OUT_VALUES = [0.04, 0.06, 0.08, 0.10, 0.12, 0.14, 0.16, 0.18]

# Base diagonal and off-diagonal values
BASE_DIAG    = np.diag(P_MATRIX_BASE).copy()          # [0.70,0.65,0.55,0.60,0.50]
BASE_OFFDIAG = P_MATRIX_BASE.copy()
np.fill_diagonal(BASE_OFFDIAG, 0)
BASE_OFFDIAG_MEAN = BASE_OFFDIAG[BASE_OFFDIAG > 0].mean()  # ≈ 0.104

sensitivity_results = []

for p_in_scale in P_IN_VALUES:
    for p_out_scale in P_OUT_VALUES:

        # Build scaled matrix
        # Scale diagonals to p_in_scale (uniform shift across all roles)
        # Scale off-diagonals proportionally to p_out_scale
        scale_diag    = p_in_scale  / BASE_DIAG.mean()
        scale_offdiag = p_out_scale / BASE_OFFDIAG_MEAN

        new_matrix = P_MATRIX_BASE.copy()
        # Scale diagonals
        for i in range(5):
            new_matrix[i, i] = min(0.95, BASE_DIAG[i] * scale_diag)
        # Scale off-diagonals
        for i in range(5):
            for j in range(5):
                if i != j:
                    new_matrix[i, j] = min(
                        new_matrix[i, i] - 0.05,
                        BASE_OFFDIAG[i, j] * scale_offdiag
                    )
                    new_matrix[i, j] = max(0.01, new_matrix[i, j])

        # Ensure p_in > p_out for all roles (SBM requirement)
        valid = all(new_matrix[i, i] > new_matrix[i, j]
                    for i in range(5) for j in range(5) if i != j)
        if not valid:
            continue

        try:
            G_s    = build_network(seed=42, p_matrix=new_matrix)
            lam2   = get_lambda2(G_s)
            reach  = get_diffusion_reach(G_s, seed=42)
            clust  = round(nx.average_clustering(G_s, weight="weight"), 4)
            dens   = round(nx.density(G_s), 4)

            sensitivity_results.append({
                "p_in":           round(p_in_scale, 3),
                "p_out":          round(p_out_scale, 3),
                "lambda2":        lam2,
                "diffusion_reach":reach,
                "reach_pct":      round(reach / N * 100, 1),
                "avg_clustering": clust,
                "density":        dens,
            })
        except Exception as e:
            print(f"  Skipped p_in={p_in_scale:.2f} p_out={p_out_scale:.2f}: {e}")

sens_df = pd.DataFrame(sensitivity_results)
print(f"\n  Grid size: {len(sens_df)} valid parameter combinations")
print(f"  λ₂ range:  {sens_df['lambda2'].min():.4f} – "
      f"{sens_df['lambda2'].max():.4f}")
print(f"  Reach range: {sens_df['reach_pct'].min():.1f}% – "
      f"{sens_df['reach_pct'].max():.1f}%")
print(f"  λ₂ at manuscript params (approx p_in=0.62, p_out=0.10): "
      f"{sens_df.loc[(sens_df['p_out']==0.10),'lambda2'].mean():.4f}")

# Pivot for heatmaps
lambda2_pivot = sens_df.pivot(
    index="p_out", columns="p_in", values="lambda2")
reach_pivot   = sens_df.pivot(
    index="p_out", columns="p_in", values="reach_pct")

# ── Figure 10B: λ₂ sensitivity heatmap ──────────────────────────────────────
fig10b, ax = plt.subplots(figsize=(7, 5))
im = ax.imshow(lambda2_pivot.values, aspect="auto",
               cmap="RdYlGn", origin="lower",
               vmin=sens_df["lambda2"].min(),
               vmax=sens_df["lambda2"].max())
cbar = plt.colorbar(im, ax=ax)
cbar.set_label("Algebraic Connectivity (λ₂)", fontsize=10)

ax.set_xticks(range(len(lambda2_pivot.columns)))
ax.set_xticklabels([f"{v:.2f}" for v in lambda2_pivot.columns],
                   fontsize=8, rotation=45)
ax.set_yticks(range(len(lambda2_pivot.index)))
ax.set_yticklabels([f"{v:.2f}" for v in lambda2_pivot.index], fontsize=8)
ax.set_xlabel("Intra-group Connection Probability (p_in)")
ax.set_ylabel("Inter-group Connection Probability (p_out)")
ax.set_title("(C) Sensitivity of λ₂ to p_in and p_out", loc="left", pad=8)

# Mark manuscript base parameters
base_col = list(lambda2_pivot.columns).index(
    min(lambda2_pivot.columns, key=lambda x: abs(x - 0.62)))
base_row = list(lambda2_pivot.index).index(
    min(lambda2_pivot.index, key=lambda x: abs(x - 0.10)))
ax.plot(base_col, base_row, marker="*", color="black",
        markersize=14, label="Manuscript parameters")
ax.legend(fontsize=8, loc="upper left")

plt.tight_layout()
fig10b.savefig(OUTPUT_DIR + "fig10b_sensitivity_lambda2.png",
               bbox_inches="tight")
plt.close(fig10b)
print("Saved: fig10b_sensitivity_lambda2.png")

# ── Figure 10C: Diffusion reach sensitivity heatmap ─────────────────────────
fig10c, ax = plt.subplots(figsize=(7, 5))
im2 = ax.imshow(reach_pivot.values, aspect="auto",
                cmap="RdYlGn", origin="lower",
                vmin=sens_df["reach_pct"].min(),
                vmax=sens_df["reach_pct"].max())
cbar2 = plt.colorbar(im2, ax=ax)
cbar2.set_label("Diffusion Reach (%)", fontsize=10)

ax.set_xticks(range(len(reach_pivot.columns)))
ax.set_xticklabels([f"{v:.2f}" for v in reach_pivot.columns],
                   fontsize=8, rotation=45)
ax.set_yticks(range(len(reach_pivot.index)))
ax.set_yticklabels([f"{v:.2f}" for v in reach_pivot.index], fontsize=8)
ax.set_xlabel("Intra-group Connection Probability (p_in)")
ax.set_ylabel("Inter-group Connection Probability (p_out)")
ax.set_title("(D) Sensitivity of Diffusion Reach to p_in and p_out",
             loc="left", pad=8)

ax.plot(base_col, base_row, marker="*", color="black",
        markersize=14, label="Manuscript parameters")
ax.legend(fontsize=8, loc="upper left")

plt.tight_layout()
fig10c.savefig(OUTPUT_DIR + "fig10c_sensitivity_diffusion.png",
               bbox_inches="tight")
plt.close(fig10c)
print("Saved: fig10c_sensitivity_diffusion.png")

