# STEP 1 — Multiple Runs: Seed Stability Analysis
# =============================================================================
print("=" * 60)
print("STEP 1 — Seed Stability Analysis (10 random seeds)")
print("=" * 60)

SEEDS = [0, 7, 13, 21, 42, 55, 77, 99, 123, 256]
seed_results = []

for s in SEEDS:
    G_s         = build_network(seed=s)
    lam2        = get_lambda2(G_s)
    reach       = get_diffusion_reach(G_s, seed=s)
    top_role    = get_top_betweenness_role(G_s)
    density     = round(nx.density(G_s), 4)
    avg_clust   = round(nx.average_clustering(G_s, weight="weight"), 4)
    n_edges     = G_s.number_of_edges()

    seed_results.append({
        "seed":           s,
        "lambda2":        lam2,
        "diffusion_reach":reach,
        "reach_pct":      round(reach / N * 100, 1),
        "top_btwn_role":  top_role,
        "density":        density,
        "avg_clustering": avg_clust,
        "n_edges":        n_edges,
    })
    print(f"  Seed {s:>3}: λ₂={lam2:.4f}  reach={reach}/{N} "
          f"({reach/N*100:.0f}%)  top_role={top_role}")

seed_df = pd.DataFrame(seed_results)

