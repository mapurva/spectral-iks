# 1. Core network builder — seed as parameter
# =============================================================================
ROLES      = ["Elder", "Healer", "Youth", "Council", "Mediator"]
ROLE_SIZES = [7, 5, 6, 4, 3]
N          = sum(ROLE_SIZES)

# Base P_MATRIX from manuscript Table 3
P_MATRIX_BASE = np.array([
    [0.70, 0.10, 0.08, 0.10, 0.08],
    [0.10, 0.65, 0.15, 0.08, 0.10],
    [0.08, 0.15, 0.55, 0.08, 0.12],
    [0.10, 0.08, 0.08, 0.60, 0.15],
    [0.08, 0.10, 0.12, 0.15, 0.50],
])

ROLE_COLORS = {
    "Elder":    "#1b6ca8",
    "Healer":   "#c0392b",
    "Youth":    "#27ae60",
    "Council":  "#8e44ad",
    "Mediator": "#e67e22",
}


def build_network(seed: int = 42,
                  p_matrix: np.ndarray = None) -> nx.Graph:
    """
    Build the indigenous knowledge-sharing network.

    Parameters
    ----------
    seed     : int   — random seed for reproducibility
    p_matrix : array — 5×5 connection probability matrix
                       (defaults to manuscript Table 3 values)
    """
    if p_matrix is None:
        p_matrix = P_MATRIX_BASE

    rng        = np.random.default_rng(seed)
    node_roles = []
    for role, size in zip(ROLES, ROLE_SIZES):
        node_roles.extend([role] * size)

    G_raw   = nx.stochastic_block_model(
                  ROLE_SIZES, p_matrix.tolist(), seed=seed)
    mapping = {}
    counters = {r: 1 for r in ROLES}
    for i in range(N):
        role        = node_roles[i]
        mapping[i]  = f"{role[:2]}-{counters[role]}"
        counters[role] += 1

    G = nx.relabel_nodes(G_raw, mapping)
    for i, (_, new) in enumerate(mapping.items()):
        G.nodes[new]["role"] = node_roles[i]

    for u, v in G.edges():
        if G.nodes[u]["role"] == G.nodes[v]["role"]:
            w = float(rng.beta(5, 2))
            G[u][v]["type"] = "intra"
        else:
            w = float(rng.beta(2, 5))
            G[u][v]["type"] = "inter"
        G[u][v]["weight"] = round(w, 3)

    return G


def get_lambda2(G: nx.Graph) -> float:
    """Return algebraic connectivity (Fiedler value) of weighted Laplacian."""
    if not nx.is_connected(G):
        return 0.0
    return round(nx.algebraic_connectivity(G, weight="weight"), 6)


def get_diffusion_reach(G: nx.Graph,
                        base_prob: float = 0.35,
                        steps: int = 8,
                        seed: int = 42) -> int:
    """
    Run independent-cascade diffusion seeded from highest-betweenness
    Elder node. Returns number of informed nodes after `steps` steps.
    """
    rng = np.random.default_rng(seed)

    # Find highest-betweenness Elder
    btwn  = nx.betweenness_centrality(G, weight="weight", normalized=True)
    elder_nodes = [n for n in G.nodes() if G.nodes[n]["role"] == "Elder"]
    if not elder_nodes:
        seed_node = max(btwn, key=btwn.get)
    else:
        seed_node = max(elder_nodes, key=lambda n: btwn[n])

    informed = {seed_node}
    for _ in range(steps):
        newly = set()
        for u in informed:
            for v in G.neighbors(u):
                if v in informed:
                    continue
                if rng.random() < base_prob * G[u][v].get("weight", 1.0):
                    newly.add(v)
        informed |= newly
    return len(informed)


def get_top_betweenness_role(G: nx.Graph) -> str:
    """Return the role of the node with highest betweenness centrality."""
    btwn = nx.betweenness_centrality(G, weight="weight", normalized=True)
    top  = max(btwn, key=btwn.get)
    return G.nodes[top]["role"]


